{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.local/schemas/plugin-manifest.schema.json",
  "title": "Aegis Plugin Manifest",
  "type": "object",
  "required": ["plugin_id", "name", "version", "signed_manifest", "enabled", "sandboxed", "permissions"],
  "properties": {
    "plugin_id": { "type": "string" },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "signed_manifest": { "type": "boolean" },
    "enabled": { "type": "boolean" },
    "sandboxed": { "type": "boolean" },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "read_events",
          "read_diagnostics",
          "read_network_metadata",
          "request_scan",
          "write_reports",
          "enterprise_admin"
        ]
      }
    }
  }
}
