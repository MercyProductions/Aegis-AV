{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.local/schemas/module-manifest.schema.json",
  "title": "Aegis Module Manifest",
  "type": "object",
  "required": ["id", "display_name", "version", "api_version", "update_channel", "enabled"],
  "properties": {
    "id": { "type": "string" },
    "display_name": { "type": "string" },
    "version": { "type": "string" },
    "api_version": { "type": "string" },
    "update_channel": { "type": "string" },
    "can_hot_reload": { "type": "boolean" },
    "enabled": { "type": "boolean" },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "permissions": { "type": "array", "items": { "type": "string" } }
  }
}
