{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.local/schemas/automation-workflow.schema.json",
  "title": "Aegis Automation Workflow",
  "type": "object",
  "required": ["id", "name", "enabled", "conditions", "actions"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "enabled": { "type": "boolean" },
    "conditions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "ransomware_score_greater_than",
              "unknown_executable_detected",
              "event_kind",
              "severity_at_least"
            ]
          },
          "value": { "type": ["string", "integer"] }
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "isolate_process_pending_confirmation",
          "quarantine_file",
          "create_incident_report",
          "notify_user",
          "upload_metadata_only",
          "request_cloud_reputation",
          "prompt_user"
        ]
      }
    }
  }
}
