{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.local/schemas/aegis-core-runtime.schema.json",
  "title": "Aegis Core Runtime",
  "type": "object",
  "required": ["version", "local_first", "cloud_optional", "capabilities"],
  "properties": {
    "version": { "type": "string" },
    "local_first": { "type": "boolean" },
    "cloud_optional": { "type": "boolean" },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["subsystem", "enabled", "owner_module", "health_score"],
        "properties": {
          "subsystem": {
            "type": "string",
            "enum": [
              "module_management",
              "event_routing",
              "permissions",
              "settings",
              "telemetry",
              "automation",
              "service_orchestration",
              "ui_synchronization",
              "plugin_loading",
              "diagnostics_coordination"
            ]
          },
          "enabled": { "type": "boolean" },
          "owner_module": { "type": "string" },
          "health_score": { "type": "integer", "minimum": 0, "maximum": 100 }
        }
      }
    }
  }
}
